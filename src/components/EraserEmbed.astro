---
interface Props {
  url: string;
  height?: number;
  title?: string;
}

const { url, height = 500, title = 'Eraser.io Architecture Diagram' } = Astro.props;

// Ensure it's the embed URL if they pasted a normal one
const embedUrl = url.includes('?') ? `${url}&embed=true` : `${url}?embed=true`;
---

<div class="eraser-embed">
  <iframe
    class="eraser-embed__frame"
    src={embedUrl}
    title={title}
    height={height}
    loading="lazy"
    allowfullscreen></iframe>
</div>
