---
/**
 * Sidebar component providing navigation and social links.
 * Unified for both desktop (aside) and mobile (drawer) views.
 */
import { SITE_TITLE, NAV_LINKS, SOCIAL_LINKS } from '../consts';
import ThemePicker from './ThemePicker.tsx';
import { Menu, X } from 'lucide-astro';
import NavigationLinks from './NavigationLinks.astro';
import { ICONS } from '../utils/icons';

const pathname = Astro.url.pathname;
---

<aside
  class="lg:w-64 xl:w-72 lg:shrink-0 bg-zinc-900 lg:h-screen lg:sticky lg:top-0 lg:flex lg:flex-col hidden relative before:hidden lg:before:block before:absolute before:inset-y-8 before:right-0 before:w-px before:bg-zinc-800/80"
>
  <!-- Desktop Sidebar Content -->
  <div
    class="space-y-8 flex-1 overflow-y-auto py-6 px-6 lg:py-10 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden"
  >
    <div class="flex items-center gap-3 px-1">
      <a
        href="/"
        class={`text-2xl font-bold pb-1 font-sacramento text-white hover:text-primary transition-colors flex-grow truncate inline-block ${pathname === '/' ? 'typing-effect' : ''}`}
        >{SITE_TITLE}</a
      >
      <ThemePicker client:load />
    </div>

    <div class="h-px bg-zinc-800/50 mx-4"></div>

    <div class="px-1">
      <p class="text-base text-zinc-400 leading-relaxed pr-2">
        I'm <a href="/"><span class="text-primary font-medium">Savitha</span></a>, a passionate and
        curious developer from India. Welcome to my digital garden 🌱.
      </p>
    </div>

    <div class="h-px bg-zinc-800/50 mx-4"></div>

    <!-- Main Navigation -->
    <nav>
      <ul class="space-y-2 font-medium text-base text-zinc-300">
        <NavigationLinks links={NAV_LINKS} pathname={pathname} variant="desktop" />
      </ul>
    </nav>

    <div class="h-px bg-zinc-800/50 mx-4"></div>

    <!-- Social Links -->
    <div class="px-1">
      <h3 class="text-base font-bold text-zinc-100 mb-4">Stay Connected</h3>
      <ul class="space-y-2 text-base text-zinc-400">
        {
          SOCIAL_LINKS.map((link) => {
            const Icon = ICONS[link.icon];
            return (
              <li>
                <a
                  href={link.href}
                  class="flex items-center gap-3 px-3 py-2 -mx-3 rounded-xl hover-lift hover:text-primary group"
                  target={link.href.startsWith('http') ? '_blank' : undefined}
                  rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                >
                  <Icon
                    class="w-4 h-4 text-zinc-500 group-hover:text-primary transition-colors"
                    aria-hidden="true"
                  />
                  {link.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </div>
</aside>

<!-- Mobile Header (Visible on small screens) -->
<div
  class="lg:hidden flex items-center justify-between p-4 border-b border-zinc-800 bg-zinc-900/60 backdrop-blur-md sticky top-0 z-40 shadow-sm"
>
  <div class="flex items-center gap-3 shrink-0">
    <a href="/" class="font-bold text-zinc-100 flex items-center gap-2">
      <span
        class={`truncate max-w-[200px] font-sacramento text-2xl pt-1 pr-1 ${pathname === '/' ? 'typing-effect' : ''}`}
        >{SITE_TITLE}</span
      >
    </a>
  </div>
  <div class="flex items-center gap-3 shrink-0">
    <ThemePicker client:load />
    <button
      id="mobile-menu-btn"
      aria-label="Open menu"
      aria-expanded="false"
      class="w-8 h-8 flex items-center justify-center text-zinc-400 hover:text-white rounded-xl hover-lift"
    >
      <Menu id="hamburger-icon" class="w-5 h-5" aria-hidden="true" />
      <X id="close-icon" class="w-5 h-5 hidden" aria-hidden="true" />
    </button>
  </div>
</div>

<!-- Mobile Drawer Navigation -->
<div
  id="mobile-drawer"
  class="lg:hidden hidden border-b border-zinc-800 bg-zinc-900/95 backdrop-blur sticky top-[57px] z-30 px-4 py-3 flex flex-col gap-1"
>
  {(<NavigationLinks links={NAV_LINKS} pathname={pathname} variant="mobile" />)}
</div>

<script>
  /**
   * Client-side script to handle mobile menu toggle.
   */
  const btn = document.getElementById('mobile-menu-btn');
  const drawer = document.getElementById('mobile-drawer');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !drawer?.classList.contains('hidden');
    drawer?.classList.toggle('hidden', isOpen);
    hamburgerIcon?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close drawer when a link is clicked
  drawer?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      drawer.classList.add('hidden');
      hamburgerIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
