---
import type { Project } from '../utils/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class:list={['project-card hover-lift-surface', project.highlight && 'hover-lift-accent']}>
  {
    project.stars > 0 && (
      <div class="project-card__stars">
        <a
          href={`${project.githubUrl}/stargazers`}
          target="_blank"
          rel="noopener noreferrer"
          class="project-card__stars-link no-hover-lift"
        >
          <span>{project.stars.toLocaleString()}</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="project-card__star-icon"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
          </svg>
        </a>
      </div>
    )
  }

  <time class="project-card__date">{project.date}</time>

  <a
    href={project.githubUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="project-card__title no-hover-lift"
  >
    {project.name}
  </a>

  {project.tagline && <p class="project-card__tagline">{project.tagline}</p>}

  <div class="project-card__actions">
    {
      project.writeup && (
        <a href={project.writeup} class="project-card__btn hover-lift-pill">
          Article
        </a>
      )
    }
    {
      project.demoUrl && (
        <a
          href={project.demoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="project-card__btn hover-lift-pill"
        >
          Demo
        </a>
      )
    }
    <a
      href={project.githubUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="project-card__btn hover-lift-pill"
    >
      Source
    </a>
  </div>
</article>
