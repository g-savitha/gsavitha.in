---
import type { Project } from '../utils/projects';

interface Props {
	project: Project;
}

const { project } = Astro.props;
---

<article
	class:list={[
		'project-card hover-lift-surface',
		project.highlight && 'hover-lift-accent',
	]}
>
	{
		project.stars > 0 && (
			<div class="project-card__stars">
				<a
					href={`${project.githubUrl}/stargazers`}
					target="_blank"
					rel="noopener noreferrer"
					class="project-card__stars-link no-hover-lift"
				>
					<span>{project.stars.toLocaleString()}</span>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="project-card__star-icon"
						viewBox="0 0 24 24"
						aria-hidden="true"
					>
						<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
					</svg>
				</a>
			</div>
		)
	}

	<time class="project-card__date">{project.date}</time>

	<a
		href={project.githubUrl}
		target="_blank"
		rel="noopener noreferrer"
		class="project-card__title no-hover-lift"
	>
		{project.name}
	</a>

	{
		project.tagline && (
			<p class="project-card__tagline">{project.tagline}</p>
		)
	}

	<div class="project-card__actions">
		{
			project.writeup && (
				<a href={project.writeup} class="project-card__btn hover-lift-pill">Article</a>
			)
		}
		{
			project.demoUrl && (
				<a
					href={project.demoUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="project-card__btn hover-lift-pill"
				>
					Demo
				</a>
			)
		}
		<a
			href={project.githubUrl}
			target="_blank"
			rel="noopener noreferrer"
			class="project-card__btn hover-lift-pill"
		>
			Source
		</a>
	</div>
</article>

<style>
	.project-card {
		position: relative;
		display: flex;
		flex-direction: column;
		padding: 1.25rem 1.25rem;
		border-radius: 1.25rem;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
		backdrop-filter: saturate(160%) blur(12px);
		-webkit-backdrop-filter: saturate(160%) blur(12px);
	}

	@media (min-width: 640px) {
		.project-card {
			padding: 1.35rem 1.5rem;
			border-radius: 1.375rem;
		}
	}

	.project-card__stars {
		position: absolute;
		top: 1.25rem;
		right: 1.25rem;
	}

	.project-card__stars-link {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		font-size: 1rem;
		font-family: var(--font-mono);
		color: #a1a1a6;
		text-decoration: none;
		transition: color 0.25s ease;
	}

	.project-card__stars-link:hover {
		color: var(--theme-color);
	}

	.project-card__star-icon {
		width: 1rem;
		height: 1rem;
		fill: currentColor;
	}

	.project-card__date {
		display: block;
		margin-bottom: 0.25rem;
		font-size: 1rem;
		font-family: var(--font-mono);
		color: #86868b;
		letter-spacing: 0.02em;
	}

	.project-card__title {
		display: block;
		padding-right: 4rem;
		font-size: 1.125rem;
		font-weight: 600;
		line-height: 1.3;
		letter-spacing: -0.02em;
		color: #f5f5f7;
		text-decoration: none;
		transition: color 0.25s ease;
	}

	@media (min-width: 640px) {
		.project-card__title {
			font-size: 1.25rem;
		}
	}

	.project-card__title:hover {
		color: var(--theme-color);
	}

	.project-card__tagline {
		margin: 0.5rem 0 1rem;
		flex: 1;
		font-size: 1rem;
		line-height: 1.55;
		color: #a1a1a6;
	}

	.project-card__actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem;
		margin-top: auto;
		padding-top: 0.25rem;
	}

	.project-card__btn {
		display: inline-flex;
		align-items: center;
		padding: 0.375rem 0.875rem;
		font-size: 1rem;
		font-weight: 500;
		color: #d2d2d7;
		text-decoration: none;
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 9999px;
		background: rgba(255, 255, 255, 0.04);
	}
</style>
