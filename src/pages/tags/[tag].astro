---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) =>
    import.meta.env.PROD ? data.draft !== true : true,
  );
  const uniqueTags = [...new Set(allPosts.map((post) => post.data.tags || []).flat())];

  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts.filter((post) => post.data.tags?.includes(tag));
    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<PageLayout title={`${tag} - ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
  <div class="page-header">
    <h1 class="text-3xl font-bold tracking-tight text-white mb-2">
      Posts tagged "<span class="text-primary">{tag}</span>"
    </h1>
  </div>

  <ul class="list-rows">
    {
      posts.map((post) => (
        <li class="list-row">
          <a href={`/blog/${post.id}`} class="list-row__link list-row__link--baseline">
            <span class="list-row__date list-row__date--offset">
              <FormattedDate date={post.data.date} />
            </span>
            <div>
              <span class="list-row__title">{post.data.title}</span>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</PageLayout>
