---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import ProfileImage from '../assets/image.png';
import FormattedDate from '../components/FormattedDate.astro';
import { ChevronRight, ExternalLink, FileText, PenBox, User } from 'lucide-astro';

import { getRecentPosts, filterDrafts } from '../utils/content';

const allPosts = await getCollection('blog');
const posts = getRecentPosts(filterDrafts(allPosts), undefined, 5);

const papers = (await getCollection('papers'))
  .sort((a, b) => (b.data.date?.valueOf() || 0) - (a.data.date?.valueOf() || 0))
  .slice(0, 5);
---

<PageLayout>
  <!-- Hero Profile Section -->
  <section
    class="flex flex-col-reverse sm:flex-row gap-8 sm:gap-12 items-start justify-between mb-20"
  >
    <div class="flex-1">
      <h1 class="text-4xl sm:text-[2.75rem] font-bold tracking-tight text-white mb-3 font-outfit">
        Hi, I'm Savitha!
      </h1>
      <p class="text-zinc-400 text-base font-mono mb-6 tracking-wide">
        Senior Software Engineer · TypeScript · React · Node.js · AWS
      </p>
      <div
        class="prose prose-base prose-invert prose-zinc text-zinc-300 leading-relaxed mb-8 max-w-2xl"
      >
        <p>
          I build full-stack web applications. Currently exploring <span
            class="text-white font-medium">distributed systems</span
          > and <span class="text-white font-medium">Agentic AI</span> while experimenting with <span
            class="text-white font-medium">AI assisted development workflows</span
          >.
        </p>
      </div>

      <div class="flex flex-wrap gap-4">
        <a
          href="/about"
          class="px-5 py-2.5 flex items-center gap-2.5 bg-zinc-800/40 border border-zinc-700/80 rounded-xl text-base font-medium text-zinc-200 hover:text-white shadow-sm hover-lift-surface group"
        >
          <User class="w-4 h-4 text-zinc-400 group-hover:text-primary transition-colors" /> Know more
        </a>
        <!-- <a
                    href="/rss.xml"
                    class="px-5 py-2.5 flex items-center gap-2.5 bg-zinc-800/40 border border-zinc-700/80 rounded-xl text-base font-medium text-zinc-200 hover:text-white shadow-sm hover-lift-surface group"
                >
                    <Mail
                        class="w-4 h-4 text-zinc-400 group-hover:text-primary transition-colors"
                    /> Email Newsletter
                </a> -->
      </div>
    </div>

    <div class="relative w-32 h-32 sm:w-48 sm:h-48 shrink-0 group">
      <div
        class="absolute inset-0 bg-primary/20 rounded-full blur-xl group-hover:bg-primary/40 group-hover:blur-2xl transition-all duration-700 -z-10 animate-pulse"
      >
      </div>

      <div
        class="w-full h-full rounded-full p-1 bg-gradient-to-tr from-primary/10 via-primary/30 to-primary/10 border-2 border-primary/20 backdrop-blur-sm shadow-xl shadow-primary/20 overflow-hidden transform transition-all duration-500 group-hover:scale-[1.05] group-hover:-translate-y-2 group-hover:rotate-3"
      >
        <Image
          src={ProfileImage}
          alt="Profile"
          class="w-full h-full object-cover rounded-full transition-transform duration-700 group-hover:scale-110 group-hover:rotate-[-3deg]"
        />
      </div>

      <div
        class="absolute -top-4 -right-4 h-8 w-8 animate-ping rounded-full bg-primary/30 blur-md [animation-duration:3s]"
      >
      </div>
      <div
        class="absolute -bottom-4 -left-2 h-6 w-6 animate-pulse rounded-full bg-primary/40 blur-sm [animation-duration:4s]"
      >
      </div>
    </div>
  </section>

  <!-- Blog Section -->
  <section class="mb-20">
    <div class="mb-8">
      <a
        href="/blog"
        class="inline-flex items-center gap-3 group/title rounded-xl px-2 py-1 -mx-2 hover-lift"
      >
        <h2
          class="text-3xl font-bold font-outfit text-white mb-2 flex items-center gap-3 group-hover/title:text-primary transition-colors"
        >
          <PenBox class="w-7 h-7 text-zinc-500 group-hover/title:text-primary transition-colors" /> Writings
        </h2>
      </a>
      <p class="text-zinc-400">Things that I've written recently</p>
    </div>

    <ul class="list-rows">
      {
        posts.map((post) => (
          <li class="list-row">
            <a href={`/blog/${post.id}`} class="list-row__link">
              <span class="list-row__date">
                <FormattedDate date={post.data.date} />
              </span>
              <span class="list-row__title list-row__title--compact">{post.data.title}</span>
              <div class="list-row__chevron">
                <ChevronRight class="w-5 h-5" aria-hidden="true" />
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- Papers Section -->
  <section>
    <div class="mb-8">
      <a
        href="/papers"
        class="inline-flex items-center gap-3 group/title rounded-xl px-2 py-1 -mx-2 hover-lift"
      >
        <h2
          class="text-3xl font-bold font-outfit text-white mb-2 flex items-center gap-3 group-hover/title:text-primary transition-colors"
        >
          <FileText
            class="w-7 h-7 text-zinc-500 group-hover/title:text-primary transition-colors"
          /> Papershelf
        </h2>
      </a>
      <p class="text-zinc-400">Things that I've read recently</p>
    </div>

    <ul class="list-rows">
      {
        papers.map((paper) => (
          <li class="list-row">
            <a
              href={paper.data.url}
              target="_blank"
              rel="noopener noreferrer"
              class="list-row__link"
            >
              <span class="list-row__date">
                {paper.data.date ? <FormattedDate date={paper.data.date} /> : 'Recent'}
              </span>
              <span class="list-row__title list-row__title--compact">{paper.data.title}</span>
              <div class="list-row__chevron">
                <ExternalLink class="w-4 h-4" aria-hidden="true" />
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</PageLayout>
