---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { ExternalLink } from 'lucide-astro';
import PageLayout from '../../layouts/PageLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';
import { getCertificationLogo } from '../../utils/certificationLogos';

const certifications = (await getCollection('certifications')).sort(
  (a, b) => (b.data.date?.valueOf() || 0) - (a.data.date?.valueOf() || 0),
);
---

<PageLayout
  title={`Certifications | ${SITE_TITLE}`}
  description="Professional certifications and courses I have completed."
>
  <div class="page-header">
    <h1 class="page-title">Certifications</h1>
    <p class="page-description">Professional certifications and courses I have completed.</p>
  </div>

  <ul class="flex flex-col max-w-2xl mx-auto divide-y divide-zinc-800/80">
    {
      certifications.map((cert) => (
        <li class="group">
          <a
            href={cert.data.url || '#'}
            target={cert.data.url ? '_blank' : '_self'}
            rel={cert.data.url ? 'noopener noreferrer' : ''}
            class="flex items-center gap-4 py-5 px-3 -mx-3 rounded-xl hover-lift"
          >
            {/* Logo badge */}
            <div class="w-14 h-14 shrink-0 rounded-xl bg-zinc-800 border border-zinc-700/60 overflow-hidden flex items-center justify-center p-2">
              {(() => {
                const logo = cert.data.thumbnail ?? getCertificationLogo(cert.data.issuer);
                return logo ? (
                  <Image src={logo} alt={cert.data.issuer} class="w-full h-full object-contain" />
                ) : (
                  <span class="text-zinc-300 text-lg font-bold">{cert.data.issuer.charAt(0)}</span>
                );
              })()}
            </div>

            {/* Content */}
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-zinc-100 group-hover:text-primary transition-colors leading-snug">
                {cert.data.title}
              </h3>
              <p class="text-base text-zinc-300 mt-0.5">{cert.data.issuer}</p>
              <p class="text-[0.875rem] text-zinc-400 mt-1 font-mono">
                {cert.data.date ? <FormattedDate date={cert.data.date} /> : '—'}
              </p>
            </div>

            {/* External link indicator */}
            {cert.data.url && (
              <div class="text-zinc-600 group-hover:text-primary transition-colors">
                <ExternalLink class="w-4 h-4 shrink-0" aria-hidden="true" />
              </div>
            )}
          </a>
        </li>
      ))
    }
  </ul>
</PageLayout>
