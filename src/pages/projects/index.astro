---
import PageLayout from '../../layouts/PageLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { SITE_TITLE } from '../../consts';
import { getProjects } from '../../utils/projects';

const GITHUB_USERNAME = 'g-savitha';
const projects = await getProjects(GITHUB_USERNAME);

const title = 'Projects';
const description =
	'A hand-picked collection of open-source projects I am proud of — apps, tools, experiments, and this website.';
const githubUrl = `https://github.com/${GITHUB_USERNAME}`;
---

<PageLayout title={`${title} | ${SITE_TITLE}`} description={description}>
	<div class="mb-12 border-b border-zinc-800/80 pb-8">
		<h1
			class="text-4xl sm:text-[2.75rem] font-bold tracking-tight text-white mb-4"
		>
			{title}
		</h1>
		<p class="text-lg text-zinc-400 max-w-2xl">
			{description}
		</p>
	</div>

	<section class="projects-showcase" aria-label="Project cards">
		<div class="projects-showcase__grid">
			{projects.map((project) => <ProjectCard project={project} />)}
		</div>
	</section>

	<p class="mt-12 pt-8 border-t border-zinc-800/80 text-zinc-400 text-center">
		Curious about the rest?
		<a
			href={githubUrl}
			target="_blank"
			rel="noopener noreferrer"
			class="text-primary hover:text-primary-hover font-medium ml-1"
		>
			Browse all my projects on GitHub →
		</a>
	</p>
</PageLayout>

<style>
	.projects-showcase {
		position: relative;
		margin: 0 -0.5rem;
		padding: 1.5rem 0.5rem 2rem;
		border-radius: 1.5rem;
	}

	.projects-showcase::before {
		content: '';
		position: absolute;
		inset: -1rem -0.5rem;
		border-radius: 1.75rem;
		background:
			radial-gradient(
				ellipse 70% 45% at 50% 0%,
				color-mix(in srgb, var(--theme-color) 12%, transparent),
				transparent 65%
			),
			radial-gradient(
				ellipse 40% 30% at 100% 50%,
				color-mix(in srgb, var(--theme-color) 6%, transparent),
				transparent 55%
			);
		pointer-events: none;
		z-index: 0;
	}

	.projects-showcase__grid {
		position: relative;
		z-index: 1;
		display: grid;
		gap: 1rem;
	}

	@media (min-width: 640px) {
		.projects-showcase__grid {
			gap: 1.25rem;
		}
	}

	@media (min-width: 768px) {
		.projects-showcase__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1280px) {
		.projects-showcase__grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}
</style>
