---
import PageLayout from '../../../layouts/PageLayout.astro';
import PdfViewer from '../../../components/PdfViewer.astro';
import { SITE_TITLE } from '../../../consts';
import { ArrowLeft } from 'lucide-astro';
---

<PageLayout
  title={`GCP ACE Cheat Sheet | ${SITE_TITLE}`}
  description="A visual mind map for the Google Cloud Associate Cloud Engineer exam."
>
  <div class="mb-4 sm:mb-6">
    <a
      href="/goodies"
      class="text-base text-zinc-500 hover:text-primary flex items-center gap-1 mb-3 rounded-lg px-2 py-1 -mx-2 w-fit hover-lift"
    >
      <ArrowLeft class="w-3.5 h-3.5" aria-hidden="true" />
      Goodies
    </a>

    <PdfViewer
      url="/gcp-ace-cheatsheet.pdf"
      title="GCP ACE Cheat Sheet"
      downloadFilename="gcp-ace-cheatsheet.pdf"
    >
      <p slot="description" class="text-zinc-400 max-w-xl text-base">
        A visual mind map covering all key topics for the Google Cloud Associate Cloud Engineer
        exam.
      </p>
    </PdfViewer>
  </div>
</PageLayout>
