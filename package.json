    "new": "node scripts/new.js",
    "audio:extract": "node scripts/audio/extract.mjs",
    "audio:check": "node scripts/audio/check.mjs",
    "audio:generate": "node scripts/audio/generate.mjs",
    "audio:upload": "node scripts/audio/upload-r2.mjs",
    "audio:reconcile": "node scripts/audio/reconcile-r2.mjs",
    "audio:enable-published": "node scripts/audio/enable-published.mjs",
    "test:audio": "node --test scripts/audio/lib/narration.test.mjs scripts/audio/lib/cache.test.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^5.0.2",
    "@astrojs/react": "^5.0.1",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@aws-sdk/client-s3": "^3.1073.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.0.6",
    "clsx": "^2.1.1",
    "kokoro-js": "^1.2.1",
    "lamejs": "^1.2.1",
    "lucide-astro": "^0.556.0",
    "lucide-react": "0.556.0",
    "mermaid": "^11.13.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "sharp": "^0.34.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "yaml": "^2.9.0"
